<?xml version="1.0"?>
<robot name="stereo_cube">

  <link name="base_link">
    <visual>
      <geometry>
        <box size="0.2 0.2 0.2"/>
      </geometry>
      <material name="gray">
        <color rgba="0.5 0.5 0.5 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <box size="0.2 0.2 0.2"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="1.0"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.0066" ixy="0.0" ixz="0.0" iyy="0.0066" iyz="0.0" izz="0.0066"/>
    </inertial>
  </link>

  <link name="stereo_camera_link">
    <visual>
      <geometry>
        <box size="0.05 0.15 0.05"/>
      </geometry>
      <material name="black">
        <color rgba="0.1 0.1 0.1 1.0"/>
      </material>
    </visual>
  </link>

  <joint name="camera_mount_joint" type="fixed">
    <parent link="base_link"/>
    <child link="stereo_camera_link"/>
    <origin xyz="0.1 0 0.125" rpy="0 0 0"/>
  </joint>

  <gazebo reference="stereo_camera_link">
    <sensor name="left_camera" type="camera">
      <pose>0 0.05 0 0 0 0</pose>
      <update_rate>30.0</update_rate>
      <always_on>true</always_on>
      <visualize>true</visualize>
      <topic>/stereo_camera/left/image_raw</topic>
      <camera>
        <horizontal_fov>1.3962634</horizontal_fov>
        <image>
          <width>640</width>
          <height>480</height>
          <format>R8G8B8</format>
        </image>
        <clip>
          <near>0.02</near>
          <far>300</far>
        </clip>
      </camera>
    </sensor>

    <sensor name="right_camera" type="camera">
      <pose>0 -0.05 0 0 0 0</pose>
      <update_rate>30.0</update_rate>
      <always_on>true</always_on>
      <visualize>true</visualize>
      <topic>/stereo_camera/right/image_raw</topic>
      <camera>
        <horizontal_fov>1.3962634</horizontal_fov>
        <image>
          <width>640</width>
          <height>480</height>
          <format>R8G8B8</format>
        </image>
        <clip>
          <near>0.02</near>
          <far>300</far>
        </clip>
      </camera>
    </sensor>
  </gazebo>

</robot>